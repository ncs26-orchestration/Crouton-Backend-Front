          <dc:Bounds x="1023" y="139" width="120" height="14"></dc:Bounds>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <di:waypoint x="1220" y="80"></di:waypoint>
