{
  "extends": "@repo/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild/node",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
