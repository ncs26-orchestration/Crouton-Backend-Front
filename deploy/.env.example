# Copied to /opt/app/.env on the VM (the provisioning script generates a real
# random POSTGRES_PASSWORD). REGISTRY and TAG are written by the deploy workflow.

# Artifact Registry image prefix, e.g.
# europe-west1-docker.pkg.dev/ncs26-solution/solution
REGISTRY=

# Image tag to run (the deploy workflow sets this to the commit SHA).
TAG=latest

POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app
