# Shared service URLs (inside the compose network)
DATABASE_URL=postgres://app:app@postgres:5432/app?sslmode=disable
REDIS_URL=redis://redis:6379/0

# Cross-service URLs
API_URL=http://api:8080
AGENT_URL=http://agent:8000

# LLM providers (optional — leave blank to run fully local via Ollama).
# Provider auto-selects by the first key set: GROQ > GOOGLE > ANTHROPIC.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Agent extractor (dev). Defaults run a local model through Ollama on the
# host. Set a provider key above to override automatically.
AGENT_EXTRACTOR_PROVIDER=ollama
AGENT_EXTRACTOR_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Auth
JWT_SECRET=change-me-in-production

# Postgres (used by the postgres container on first boot)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
