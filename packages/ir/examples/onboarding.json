{
  "version": "0.1",
  "metadata": {
    "name": "onboarding",
    "description": "New-hire onboarding with parallel tasks. HR prepares contract, sales team lead prepares workstation, and IT provisions accounts in parallel; then a welcome email goes out.",
    "tenant_id": "demo",
    "source_ids": []
  },
  "actors": [
    { "id": "hr",         "name": "Demo (admins)",   "kind": "group", "is_ref": { "group_id": "camunda-admin" } },
    { "id": "sales_lead", "name": "John (sales)",    "kind": "group", "is_ref": { "group_id": "sales" } },
    { "id": "it",         "name": "Peter (management)", "kind": "group", "is_ref": { "group_id": "management" } }
  ],
  "tasks": [
    {
      "id": "prepare_contract",
      "name": "Prepare contract",
      "type": "user",
      "actor_ref": "hr",
      "form_ref": "contract_form",
      "binding": { "candidate_group_id": "camunda-admin" }
    },
    {
      "id": "prepare_workstation",
      "name": "Prepare workstation",
      "type": "user",
      "actor_ref": "sales_lead",
      "binding": { "candidate_group_id": "sales" }
    },
    {
      "id": "provision_accounts",
      "name": "Provision accounts",
      "type": "user",
      "actor_ref": "it",
      "binding": { "candidate_group_id": "management" }
    },
    {
      "id": "send_welcome",
      "name": "Send welcome email",
      "type": "service",
      "binding": {
        "system_ref": "m365",
        "capability": "user.notify.email",
        "params": { "template": "welcome_new_hire" }
      }
    }
  ],
  "gateways": [
    { "id": "g_split", "type": "parallel" },
    { "id": "g_join",  "type": "parallel" }
  ],
  "events": [
    { "id": "e_start", "type": "start" },
    { "id": "e_end",   "type": "end" }
  ],
  "flows": [
    { "id": "f1", "from": "e_start", "to": "g_split" },
    { "id": "f2", "from": "g_split", "to": "prepare_contract" },
    { "id": "f3", "from": "g_split", "to": "prepare_workstation" },
    { "id": "f4", "from": "g_split", "to": "provision_accounts" },
    { "id": "f5", "from": "prepare_contract",    "to": "g_join" },
    { "id": "f6", "from": "prepare_workstation", "to": "g_join" },
    { "id": "f7", "from": "provision_accounts",  "to": "g_join" },
    { "id": "f8", "from": "g_join", "to": "send_welcome" },
    { "id": "f9", "from": "send_welcome", "to": "e_end" }
  ],
  "forms": [
    {
      "id": "contract_form",
      "fields": [
        { "id": "full_name", "label": "Full name",     "type": "string", "required": true },
        { "id": "start_date","label": "Start date",    "type": "date",   "required": true },
        { "id": "role_title","label": "Role title",    "type": "string" }
      ]
    }
  ]
}
